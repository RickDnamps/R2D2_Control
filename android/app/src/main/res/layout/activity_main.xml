<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080c14">

    <!-- Main WebView — full screen, banner overlays on top when offline -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Offline banner — slides down when offline, slides up (hidden) when online -->
    <LinearLayout
        android:id="@+id/statusBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="#0d0014">

            <TextView
                android:id="@+id/statusDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#ff2244"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HORS LIGNE"
                android:textColor="#ff2244"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/statusHost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="192.168.4.1:5000"
                android:textColor="#00aaff"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

        <!-- 1dp separator line at bottom of banner -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#330033" />

    </LinearLayout>

    <!-- Loading overlay — shown only on initial load -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#080c14"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R2-D2"
            android:textColor="#00aaff"
            android:textSize="48sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTROL SYSTEM"
            android:textColor="#8899aa"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:layout_marginTop="4dp" />

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"
            android:indeterminateTint="#00aaff" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chargement du dashboard..."
            android:textColor="#8899aa"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
